# Copy this file to `keystore.properties` (which is gitignored) and fill in your
# real values to build a signed release .aab locally.
#
# Create the keystore once with:
#   keytool -genkey -v -keystore staysathi-upload.jks \
#           -keyalg RSA -keysize 2048 -validity 10000 -alias staysathi
#
# Keep staysathi-upload.jks and these passwords safe and backed up — losing them
# means you can never update the app on the Play Store (unless enrolled in Play
# App Signing, which is strongly recommended — see PLAYSTORE.md).

storeFile=../staysathi-upload.jks
storePassword=CHANGE_ME
keyAlias=staysathi
keyPassword=CHANGE_ME
