# Copy to .env for local runs:  cp .env.example .env
# .env is gitignored — never commit real secrets.

# Port the server listens on (hosts inject their own; 5050 for local dev).
PORT=5050

# Where the JSON datastore is written. Point this at a mounted persistent
# volume in production (Render disk / Fly volume / Docker volume).
# Leave unset locally to use server/data.
# DATA_DIR=/data

# Seeded admin account (created on first boot if no admin exists).
# CHANGE THESE before going to production — the defaults are public.
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=admin123

# Reported by GET /health. CI/CD sets this to the git commit SHA.
APP_VERSION=dev
